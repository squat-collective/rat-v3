# platform/.env — THE fact sheet (ADR-050 / DX-5): every credential, endpoint, and demo
# knob exactly once. Consumed by BOTH topologies:
#   - compose (attach mode + infra): docker-compose loads this file automatically
#     (the project dir is this dir, via `-f platform/compose*.yaml`).
#   - launch mode (rat as the launcher): load it into rat's process first —
#         set -a; . ./.env; set +a
#         rat serve --plane plugins.yaml
#     plugins.yaml interpolates ${VAR} at load (ADR-050); a missing var fails loud,
#     and `rat validate --plane plugins.yaml` reports it by name pre-boot.
#
# Committed on purpose: these are DEMO credentials. A real deployment keeps its .env
# out of git — and real secrets in a secret-backend (see plugins/secret/vault-py),
# not in env at all.

PLATFORM_PG_USER=ducklake
PLATFORM_PG_PASSWORD=ducklake
PLATFORM_PG_DB=ducklake

PLATFORM_S3_USER=minioadmin
PLATFORM_S3_PASSWORD=minioadmin

# attach mode: where plugins reach the gateway (the compose service name)
PLATFORM_GATEWAY=rat-serve:7777

# launch mode: where rat-launched containers reach the host-published infra
PLATFORM_INFRA_HOST=host.containers.internal
PLATFORM_INFRA_PG_PORT=55440
PLATFORM_INFRA_S3_PORT=59010

# demo knobs (a real plane would schedule hourly, not every 20s)
PLATFORM_SCHEDULE_INTERVAL=20
PLATFORM_PIPELINE_TARGET=gold_daily_revenue
