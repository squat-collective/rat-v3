{
  "_comment": "RAT catalog/v1 conformance vectors — ADR-003 shared golden data. The SINGLE source of truth for the catalog axis. Both independent references (Go: plugins/catalog/inmemory-go, Python: plugins/catalog/inmemory-py) load THIS file and drive CatalogService (GetTable / CreateBranch / MergeBranch / RegisterTable / CommitTable) over real gRPC. Catalog owns table metadata + git-like branch/version semantics — the basis for branch-isolated pipeline runs. The references model a deterministic snapshot scheme so two impls stay in lockstep: branches are global; the reference SEEDS one table ('warehouse.sales.orders') on branch 'main' at snapshot 'snap-0'; CreateBranch copies the source branch's snapshot; MergeBranch bumps a global counter and sets the target branch to 'snap-<counter>' (first merge -> 'snap-1'). The lifecycle is STATEFUL (steps share one catalog, run in order); a step with expect.code asserts a gRPC error mid-sequence (used for the optimistic-concurrency reject after the target has moved). The MERGE-SAFETY contract (reviews/06 #8) is what's under test: optimistic concurrency (expected_into_snapshot) + idempotency (idempotency_key -> already_applied). COMMIT-LINKAGE (ADR-010 / reviews/08 B1): RegisterTable creates a new output table (idempotent, no ALREADY_EXISTS); CommitTable records the snapshot a format.Write produced for a (table, branch) — writer-supplied snapshot_id echoed back — under the SAME safety model as MergeBranch (expected_snapshot CAS + idempotency_key -> already_applied). expect.snapshot_id asserts the exact committed value (linkage); expect.snapshot_id_set asserts only non-empty (merge mints its own).",
  "axis": "catalog/v1",
  "seed_table": "warehouse.sales.orders",
  "lifecycle": [
    {
      "step": "get_table_main",
      "op": "get_table",
      "identifier": "warehouse.sales.orders",
      "branch": "",
      "expect": {"table": {"identifier": "warehouse.sales.orders", "branch": "main"}}
    },
    {
      "step": "create_branch",
      "op": "create_branch",
      "branch": "run-42",
      "from_branch": "main",
      "expect": {"branch": "run-42"}
    },
    {
      "step": "get_table_on_branch",
      "op": "get_table",
      "identifier": "warehouse.sales.orders",
      "branch": "run-42",
      "expect": {"table": {"identifier": "warehouse.sales.orders", "branch": "run-42"}}
    },
    {
      "step": "merge_branch_ok",
      "op": "merge_branch",
      "branch": "run-42",
      "into_branch": "main",
      "expected_into_snapshot": "snap-0",
      "idempotency_key": "run-42-merge",
      "expect": {"already_applied": false, "snapshot_id_set": true}
    },
    {
      "step": "merge_branch_idempotent_retry",
      "op": "merge_branch",
      "branch": "run-42",
      "into_branch": "main",
      "idempotency_key": "run-42-merge",
      "expect": {"already_applied": true, "snapshot_id_set": true}
    },
    {
      "step": "merge_branch_stale_snapshot",
      "op": "merge_branch",
      "branch": "run-42",
      "into_branch": "main",
      "expected_into_snapshot": "snap-0",
      "idempotency_key": "different-key",
      "expect": {"code": "FAILED_PRECONDITION"}
    },
    {
      "step": "register_table_new",
      "op": "register_table",
      "identifier": "warehouse.sales.summary",
      "branch": "",
      "expect": {"table": {"identifier": "warehouse.sales.summary", "branch": "main"}}
    },
    {
      "step": "register_table_idempotent",
      "op": "register_table",
      "identifier": "warehouse.sales.summary",
      "branch": "",
      "expect": {"table": {"identifier": "warehouse.sales.summary", "branch": "main"}}
    },
    {
      "step": "commit_table_new",
      "op": "commit_table",
      "identifier": "warehouse.sales.summary",
      "branch": "",
      "snapshot_id": "snap-w1",
      "idempotency_key": "summary-load-1",
      "expect": {"already_applied": false, "snapshot_id": "snap-w1"}
    },
    {
      "step": "commit_table_idempotent_retry",
      "op": "commit_table",
      "identifier": "warehouse.sales.summary",
      "branch": "",
      "snapshot_id": "snap-w2-must-be-ignored",
      "idempotency_key": "summary-load-1",
      "expect": {"already_applied": true, "snapshot_id": "snap-w1"}
    },
    {
      "step": "commit_table_stale_snapshot",
      "op": "commit_table",
      "identifier": "warehouse.sales.summary",
      "branch": "",
      "snapshot_id": "snap-w3",
      "expected_snapshot": "snap-WRONG",
      "idempotency_key": "summary-load-2",
      "expect": {"code": "FAILED_PRECONDITION"}
    },
    {
      "step": "commit_table_cas_ok",
      "op": "commit_table",
      "identifier": "warehouse.sales.summary",
      "branch": "",
      "snapshot_id": "snap-w4",
      "expected_snapshot": "snap-w1",
      "idempotency_key": "summary-load-3",
      "expect": {"already_applied": false, "snapshot_id": "snap-w4"}
    }
  ],
  "errors": [
    {
      "step": "get_unknown_table",
      "op": "get_table",
      "identifier": "warehouse.sales.ghosts",
      "expect": {"code": "NOT_FOUND"}
    },
    {
      "step": "get_empty_identifier",
      "op": "get_table",
      "identifier": "",
      "expect": {"code": "INVALID_ARGUMENT"}
    },
    {
      "step": "register_empty_identifier",
      "op": "register_table",
      "identifier": "",
      "expect": {"code": "INVALID_ARGUMENT"}
    },
    {
      "step": "commit_unregistered_table",
      "op": "commit_table",
      "identifier": "warehouse.sales.ghosts",
      "snapshot_id": "snap-x",
      "expect": {"code": "NOT_FOUND"}
    },
    {
      "step": "commit_empty_snapshot",
      "op": "commit_table",
      "identifier": "warehouse.sales.orders",
      "snapshot_id": "",
      "expect": {"code": "INVALID_ARGUMENT"}
    }
  ]
}
