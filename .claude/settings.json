{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(buf breaking *)",
      "Bash(buf build *)",
      "Bash(buf format *)",
      "Bash(buf generate *)",
      "Bash(buf lint *)",
      "Bash(go build *)",
      "Bash(go fmt *)",
      "Bash(go generate *)",
      "Bash(go mod *)",
      "Bash(go run *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "Bash(git status)",
      "Bash(git tag *)",
      "Bash(make breaking)",
      "Bash(make build)",
      "Bash(make check)",
      "Bash(make check *)",
      "Bash(make composition)",
      "Bash(make conformance)",
      "Bash(make core-test)",
      "Bash(make gen-check)",
      "Bash(make gen-sdks)",
      "Bash(make help)",
      "Bash(make lint)",
      "Bash(make validate-manifests)",
      "Bash(make validate-vectors)",
      "Bash(make verify)",
      "Bash(podman build *)",
      "Bash(podman compose *)",
      "Bash(podman run *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/contracts-check.sh"
          }
        ]
      }
    ]
  }
}
